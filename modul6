
-- 1. MEMBUAT DATABASE
-- ============================================================
DROP DATABASE IF EXISTS db_subquery;
CREATE DATABASE db_subquery;
USE db_subquery;

-- 2. MEMBUAT TABEL
-- ============================================================

-- Tabel Jurusan
CREATE TABLE jurusan (
    kd_jur VARCHAR(5) PRIMARY KEY,
    nama_jur VARCHAR(50)
);

-- Tabel Mahasiswa
CREATE TABLE mahasiswa (
    nim VARCHAR(15) PRIMARY KEY,
    nama VARCHAR(50),
    alamat VARCHAR(100),
    jk ENUM('L', 'P'),
    kd_jur VARCHAR(5),
    FOREIGN KEY (kd_jur) REFERENCES jurusan(kd_jur)
);

-- Tabel Dosen
CREATE TABLE dosen (
    kode_dos VARCHAR(5) PRIMARY KEY,
    nama_dos VARCHAR(50),
    kd_jur VARCHAR(5),
    jabatan VARCHAR(30),
    FOREIGN KEY (kd_jur) REFERENCES jurusan(kd_jur)
);

-- Tabel Matakuliah
CREATE TABLE matakuliah (
    kd_mk VARCHAR(10) PRIMARY KEY,
    nama_mk VARCHAR(50),
    sks INT,
    semester INT,
    kode_dos VARCHAR(5),
    FOREIGN KEY (kode_dos) REFERENCES dosen(kode_dos)
);

-- Tabel Ambil_MK
CREATE TABLE ambil_mk (
    nim VARCHAR(15),
    kd_mk VARCHAR(10),
    nilai CHAR(2),
    PRIMARY KEY (nim, kd_mk),
    FOREIGN KEY (nim) REFERENCES mahasiswa(nim),
    FOREIGN KEY (kd_mk) REFERENCES matakuliah(kd_mk)
);

