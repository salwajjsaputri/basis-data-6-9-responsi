-- 4. QUERY UNTUK SOAL TUGAS
-- ============================================================

-- Soal 1: Dapatkan kode dan nama matakuliah dosen yang menjadi Ketua Jurusan Teknik Elektro
-- ============================================================
SELECT '=== SOAL 1 ===' AS ' ';
SELECT kd_mk, nama_mk
FROM matakuliah
WHERE kode_dos = (
    SELECT kode_dos
    FROM dosen
    WHERE kd_jur = (
        SELECT kd_jur
        FROM jurusan
        WHERE nama_jur = 'Teknik Elektro'
    )
    AND jabatan = 'Ketua'
);

-- Soal 2: Dapatkan data mahasiswa yang tidak mengambil matakuliah
-- ============================================================
SELECT '=== SOAL 2 ===' AS ' ';
SELECT *
FROM mahasiswa
WHERE nim NOT IN (
    SELECT nim
    FROM ambil_mk
);

-- Soal 3: Dapatkan data dosen yang mengajar matakuliah di atas semester 3
-- ============================================================
SELECT '=== SOAL 3 ===' AS ' ';
SELECT *
FROM dosen
WHERE kode_dos IN (
    SELECT kode_dos
    FROM matakuliah
    WHERE semester > 3
);

-- Soal 4: Dapatkan data matakuliah dosen yang bukan merupakan Ketua Jurusan Teknik Elektro
-- ============================================================
SELECT '=== SOAL 4 ===' AS ' ';
SELECT *
FROM matakuliah
WHERE kode_dos NOT IN (
    SELECT kode_dos
    FROM dosen
    WHERE jabatan = 'Ketua' 
    AND kd_jur = (
        SELECT kd_jur
        FROM jurusan
        WHERE nama_jur = 'Teknik Elektro'
    )
);

-- Soal 5: Dapatkan data dosen pengajar matakuliah yang tidak diambil oleh mahasiswa
-- ============================================================
SELECT '=== SOAL 5 ===' AS ' ';
SELECT *
FROM dosen
WHERE kode_dos IN (
    SELECT kode_dos
    FROM matakuliah
    WHERE kd_mk NOT IN (
        SELECT kd_mk
        FROM ambil_mk
    )
);

-- Soal 6: Dapatkan data dosen pengajar matakuliah dengan sks lebih besar dari sembarang sks
-- ============================================================
SELECT '=== SOAL 6 ===' AS ' ';
SELECT *
FROM dosen
WHERE kode_dos IN (
    SELECT kode_dos
    FROM matakuliah
    WHERE sks > ANY (
        SELECT sks
        FROM matakuliah
    )
);

-- Soal 7: Dapatkan data mahasiswa yang tinggal satu wilayah dengan dosen yang bukan Ketua Jurusan Teknik Elektro
-- ============================================================
SELECT '=== SOAL 7 ===' AS ' ';
SELECT *
FROM mahasiswa
WHERE alamat IN (
    SELECT alamat
    FROM dosen
    WHERE kd_jur = (
        SELECT kd_jur
        FROM jurusan
        WHERE nama_jur = 'Teknik Elektro'
    )
    AND jabatan != 'Ketua'
);

-- Soal 8: Dapatkan data mahasiswa yang diajar oleh Ketua Jurusan Teknik Elektro
-- ============================================================
SELECT '=== SOAL 8 ===' AS ' ';
SELECT DISTINCT m.*
FROM mahasiswa m
JOIN ambil_mk a ON m.nim = a.nim
WHERE a.kd_mk IN (
    SELECT kd_mk
    FROM matakuliah
    WHERE kode_dos = (
        SELECT kode_dos
        FROM dosen
        WHERE jabatan = 'Ketua' 
        AND kd_jur = (
            SELECT kd_jur
            FROM jurusan
            WHERE nama_jur = 'Teknik Elektro'
        )
    )
);

