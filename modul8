-- 4. MANAJEMEN USER DAN HAK AKSES
-- ============================================================

-- Membuat user (jalankan sebagai root)
-- ============================================================
-- CREATE USER 'user_admin'@'localhost' IDENTIFIED BY 'admin123';
-- CREATE USER 'user_mhs'@'localhost' IDENTIFIED BY 'mhs123';
-- CREATE USER 'user_dosen'@'localhost' IDENTIFIED BY 'dosen123';

-- Memberikan hak akses (jalankan sebagai root)
-- ============================================================

-- Hak akses untuk user_admin (semua akses ke db_kampus)
-- GRANT ALL PRIVILEGES ON db_kampus.* TO 'user_admin'@'localhost';

-- Hak akses untuk user_mhs (SELECT, INSERT, UPDATE pada matakuliah)
-- GRANT SELECT, INSERT, UPDATE ON db_kampus.matakuliah TO 'user_mhs'@'localhost';

-- Hak akses untuk user_dosen (SELECT, INSERT, UPDATE, DELETE pada mahasiswa)
-- GRANT SELECT, INSERT, UPDATE, DELETE ON db_kampus.mahasiswa TO 'user_dosen'@'localhost';

-- Melihat hak akses user (jalankan sebagai root)
-- ============================================================
-- SHOW GRANTS FOR 'user_admin'@'localhost';
-- SHOW GRANTS FOR 'user_mhs'@'localhost';
-- SHOW GRANTS FOR 'user_dosen'@'localhost';

-- Mencabut hak akses (contoh)
-- ============================================================
-- REVOKE INSERT, UPDATE ON db_kampus.matakuliah FROM 'user_mhs'@'localhost';

-- 5. IMPLEMENTASI RBAC (Role-Based Access Control)
-- ============================================================

-- Membuat role
CREATE ROLE 'role_keuangan'@'localhost';

-- Memberikan hak akses ke role
GRANT SELECT, UPDATE ON db_kampus.tagihan TO 'role_keuangan'@'localhost';

-- Melihat hak akses role
SHOW GRANTS FOR 'role_keuangan'@'localhost';

-- Membuat user baru untuk role
-- CREATE USER 'user_keu'@'localhost' IDENTIFIED BY 'keu123';

-- Memberikan role ke user
-- GRANT 'role_keuangan'@'localhost' TO 'user_keu'@'localhost';

-- Mengaktifkan default role
-- SET DEFAULT ROLE 'role_keuangan'@'localhost' TO 'user_keu'@'localhost';

-- Menampilkan hak akses user_keu
-- SHOW GRANTS FOR 'user_keu'@'localhost';

