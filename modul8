

-- 1. MEMBUAT DATABASE
-- ============================================================
DROP DATABASE IF EXISTS db_kampus;
CREATE DATABASE db_kampus;
USE db_kampus;

-- 2. MEMBUAT TABEL
-- ============================================================

-- Tabel Mahasiswa
CREATE TABLE mahasiswa (
    nim CHAR(10) PRIMARY KEY,
    nama VARCHAR(50),
    jurusan VARCHAR(30)
);

-- Tabel Matakuliah
CREATE TABLE matakuliah (
    kode_mk CHAR(6) PRIMARY KEY,
    nama_mk VARCHAR(50),
    sks INT
);

-- Tabel Dosen
CREATE TABLE dosen (
    nip CHAR(10) PRIMARY KEY,
    nama VARCHAR(50),
    bidang VARCHAR(30)
);

-- Tabel Tagihan (untuk RBAC)
CREATE TABLE tagihan (
    id_tagihan INT AUTO_INCREMENT PRIMARY KEY,
    nim CHAR(10),
    jumlah INT,
    keterangan VARCHAR(100),
    FOREIGN KEY (nim) REFERENCES mahasiswa(nim)
);

